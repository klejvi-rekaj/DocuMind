# ===== BACKEND ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in the actual values

# 1. AI Output Generation Models
# OpenAI (Required if using OpenAI embeddings/models)
OPENAI_API_KEY=
# Local Fallback Model Path (if applicable)
# LOCAL_MODEL_PATH=/path/to/local/model.bin

# 2. Security & Auth (Required)
# Generate a secure random string for JWT signing
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# 3. Environment Context
ENVIRONMENT=development # or 'production'
PORT=8000

# 4. Storage paths
# Make sure to provision the data folder if deploying
FAISS_INDEX_PATH=./data/faiss/index.bin
PDF_UPLOAD_DIR=./data/uploads/
